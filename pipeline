pipeline{
    agent any
    environment {
        scannerHome=tool "mysonar"
    }
    stages{
        stage("clean workspace"){
            steps{
                cleanWs()
            }
        }
        stage("code"){
            steps{
                git branch: 'main', url: 'https://github.com/Sahithi0602/Zomato-Repo.git'
            }
        }
        stage("CODE QUALITY ANALYSIS"){
            steps{
                   withSonarQubeEnv("mysonar") {
                      sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=zomato"
                   }
            }        
        }
        stage("Quality gates"){
            steps{
                script {
                  waitForQualityGate abortPipeline: false, credentialsId: 'sonar-password'  
                }
            }
        }
        stage("BUILD"){
            steps{
                sh "docker build -t image1 ."
            }
        }
        stage("image scan"){
            steps{
                sh "trivy image image1"
            }
        }
        stage("tag"){
            steps{
                sh 'docker tag image1 sahithi0622/nodedeploymentproject:zomato'
            }
        }
        stage("push"){
            steps{
                script{
                    withDockerRegistry(credentialsId: 'passworddockerhub') {
                        sh "docker push sahithi0622/nodedeploymentproject:zomato"
                    }
                }
            }
        }    
        stage("container"){
            steps{
                sh "docker run -itd --name zomatoproject -p 3000:3000 sahithi0622/nodedeploymentproject:zomato "
             }
         }    
     }
 }    
